{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SQLRite",
  "version": "0.1.23",
  "identifier": "com.sqlrite.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SQLRite",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "SQLRite — a small embeddable SQLite clone",
    "longDescription": "SQLRite is a small, embeddable SQLite-inspired database engine written in Rust. This desktop app provides a GUI for browsing and querying SQLRite databases.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
